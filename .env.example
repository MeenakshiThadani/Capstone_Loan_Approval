# ─────────────────────────────────────────────────────────────────────────────
# Loan Approval Agent – Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Required: your Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Claude Model ──────────────────────────────────────────────────────────────
# Model used by all agents and the orchestrator's final reasoning step.
# Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# ── FastAPI Service ───────────────────────────────────────────────────────────
# Host and port for the REST microservice.
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit UI ──────────────────────────────────────────────────────────────
# The URL of the FastAPI service that the Streamlit app calls.
API_BASE_URL=http://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Notification Mocks ────────────────────────────────────────────────────────
# In production, replace with real SMTP / SMS gateway credentials.
NOTIFICATION_EMAIL_FROM=noreply@loanapproval.local
NOTIFICATION_SMS_FROM=+10000000000
